# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local (Docker):
MONGODB_URI=mongodb://yallaplay:yallaplay_dev_secret@localhost:27017/yallaplay?authSource=admin

# Atlas (Production):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/yallaplay?retryWrites=true&w=majority

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_64_byte_hex_string_for_production
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_64_byte_hex_string
JWT_QR_SECRET=CHANGE_ME_generate_a_third_64_byte_hex_string_for_qr_tokens

# ─── SMS (OTP) ─────────────────────────────────────────────────────────────────
SMS_PROVIDER=console              # 'console' logs OTP to terminal (dev only)
# SMS_PROVIDER=twilio             # Uncomment for production
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Firebase (Push Notifications) ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=            # Paste the full JSON private key string
FIREBASE_CLIENT_EMAIL=

# ─── Weather API ───────────────────────────────────────────────────────────────
WEATHER_API_KEY=                 # OpenWeatherMap free tier
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ─── Frontend URLs (CORS) ──────────────────────────────────────────────────────
ADMIN_DASHBOARD_URL=http://localhost:3001
